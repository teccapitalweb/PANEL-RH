rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /empresas/{empresaId} {

      // Aspirantes: el kiosko (sin login) SOLO puede crear.
      // Leer y actualizar (decisión/notas): solo RH autenticado.
      match /aspirantes/{aspiranteId} {
        allow create: if true;
        allow read, update: if request.auth != null;
        allow delete: if false;
      }

      // Config (mensaje final + puestos): cualquiera la lee (el kiosko la necesita),
      // solo RH autenticado la escribe.
      match /config/{docId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}
